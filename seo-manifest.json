---
layout: null
permalink: /seo-manifest.json
sitemap: false
---
{
  "manifest_version": 1,
  "generated_at": "{{ site.time | date_to_xmlschema }}",
  "generator": "jekyll-base",
  "site_url": {{ site.url | jsonify }},
  "posts": [
    {% for post in site.posts %}{
      "url": {{ post.url | jsonify }},
      "path": {{ post.path | jsonify }},
      "title": {{ post.title | jsonify }},
      "description": {{ post.description | jsonify }},
      "date": "{{ post.date | date: '%Y-%m-%d' }}",
      "last_modified_at": {% if post.last_modified_at %}"{{ post.last_modified_at | date: '%Y-%m-%d' }}"{% else %}null{% endif %},
      "categories": {{ post.categories | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "word_count": {{ post.content | strip_html | number_of_words }}
    }{% unless forloop.last %},{% endunless %}{% endfor %}
  ]
}
